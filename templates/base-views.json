{
  "Projects": [
    {
      "name": "Project Directory",
      "type": "gallery",
      "visible_fields": ["ID", "Title", "Status", "Repo Path", "Repo URL", "Wiki URL", "Default Branch", "Current Focus", "AI Summary", "Search Keywords"],
      "card": {"cover_field": null}
    },
    {
      "name": "Project Index",
      "type": "grid",
      "visible_fields": ["ID", "Title", "Status", "Repo Path", "Repo URL", "Wiki URL", "Default Branch", "Current Focus", "AI Summary", "Search Keywords"]
    }
  ],
  "Areas": [
    {
      "name": "Area Risk Board",
      "type": "kanban",
      "visible_fields": ["ID", "Title", "Project", "Status", "Code Paths", "Owner", "Risk Level", "AI Summary", "Search Keywords"],
      "group": {"group_config": [{"field": "Risk Level", "desc": false}]},
      "card": {"cover_field": null}
    },
    {
      "name": "Area Index",
      "type": "grid",
      "visible_fields": ["ID", "Title", "Project", "Status", "Code Paths", "Owner", "Risk Level", "AI Summary", "Search Keywords"]
    }
  ],
  "Tasks": [
    {
      "name": "Task Board",
      "type": "kanban",
      "visible_fields": ["ID", "Title", "Project", "Area", "Status", "Priority", "Type", "Next Action", "Due At", "AI Summary", "Search Keywords", "Source URL"],
      "filter": {"logic": "and", "conditions": [["Status", "intersects", ["Inbox", "Ready", "Doing", "Blocked", "Review", "Verify"]]]},
      "group": {"group_config": [{"field": "Status", "desc": false}]},
      "sort": {"sort_config": [{"field": "Priority", "desc": false}, {"field": "Due At", "desc": false}]},
      "card": {"cover_field": null}
    },
    {
      "name": "Task Timeline",
      "type": "gantt",
      "visible_fields": ["ID", "Title", "Project", "Area", "Status", "Priority", "Started At", "Due At", "Next Action"],
      "timebar": {"start_time": "Started At", "end_time": "Due At", "title": "Title"},
      "group": {"group_config": [{"field": "Status", "desc": false}]}
    },
    {
      "name": "Due Calendar",
      "type": "calendar",
      "visible_fields": ["ID", "Title", "Project", "Area", "Status", "Priority", "Due At", "Next Action"],
      "timebar": {"start_time": "Due At", "end_time": "Due At", "title": "Title"}
    },
    {
      "name": "Done Tasks",
      "type": "gallery",
      "visible_fields": ["ID", "Title", "Project", "Area", "Status", "Completed At", "AI Summary", "Source URL"],
      "filter": {"logic": "and", "conditions": [["Status", "intersects", ["Done"]]]},
      "card": {"cover_field": null}
    }
  ],
  "Bugfixes": [
    {
      "name": "Bug Triage",
      "type": "kanban",
      "visible_fields": ["ID", "Title", "Project", "Area", "Status", "Symptom", "Root Cause", "Fix Summary", "Verification Result", "Regression Risk", "Next Time Check", "Search Keywords", "Source URL"],
      "filter": {"logic": "and", "conditions": [["Status", "intersects", ["Inbox", "Doing", "Fixed"]]]},
      "group": {"group_config": [{"field": "Status", "desc": false}]},
      "card": {"cover_field": null}
    },
    {
      "name": "Verified Fix Library",
      "type": "gallery",
      "visible_fields": ["ID", "Title", "Project", "Area", "Status", "Root Cause", "Fix Summary", "Verification Commands", "Verification Result", "Commit SHA", "Search Keywords"],
      "filter": {"logic": "and", "conditions": [["Status", "intersects", ["Verified"]]]},
      "card": {"cover_field": null}
    }
  ],
  "Pitfalls": [
